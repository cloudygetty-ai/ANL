# ── Copy this to .env and fill in your values ──────────────────────────────
# Expo reads EXPO_PUBLIC_* at build time and injects into the JS bundle.
# Never commit .env — it's in .gitignore already.

# Mapbox — https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.XXXXXXXX

# Supabase — https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX

# Your backend API (for LiveKit token endpoint, Stripe payment sheet, uploads)
# Local dev:    http://localhost:3001
# Production:   https://api.allnightlong.app
EXPO_PUBLIC_API_URL=http://localhost:3001

# Stripe — https://dashboard.stripe.com/apikeys
# Use the PUBLISHABLE key here (safe to include in client bundle)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Expo Push Notifications project ID
# Found at: https://expo.dev/accounts/[your-account]/projects/[your-project] > Settings > Project ID
EXPO_PUBLIC_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Backend-only vars (never use EXPO_PUBLIC_ prefix for these) ────────────
# These go in backend/.env, not here — listed for reference only.
#
# STRIPE_SECRET_KEY=your-stripe-secret-key-here
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_PLUS_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_PREMIUM_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX
# JWT_SECRET=your-jwt-secret-min-32-chars
# DATABASE_URL=postgresql://user:pass@localhost:5432/anl
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# AWS_REGION=us-east-1
# S3_BUCKET=anl-uploads
# APP_DEEP_LINK=anl
# CORS_ORIGIN=https://allnightlong.app
# WEBRTC_PORT=4001
