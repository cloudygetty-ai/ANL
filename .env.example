# Database
DATABASE_URL=postgresql://user:pass@host:5432/anl?connection_limit=3&pool_timeout=10
DIRECT_URL=postgresql://user:pass@host:5432/anl

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# LiveKit
LIVEKIT_API_KEY=APIxxxx
LIVEKIT_API_SECRET=xxxx
LIVEKIT_WS_URL=wss://your-instance.livekit.cloud

# AWS S3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=xxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=anl-media

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
PORT=3000
NODE_ENV=production
JWT_SECRET=minimum-32-char-random-secret
CORS_ORIGIN=https://your-expo-url
REVEAL_HMAC_SECRET=minimum-32-char-random-secret

# Expo
EXPO_PUBLIC_API_URL=https://anl-api.fly.dev
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_LIVEKIT_WS_URL=wss://your-instance.livekit.cloud
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ...
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id
