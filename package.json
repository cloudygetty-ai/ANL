{
  "name": "anl-allnightlong",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start":          "expo start",
    "android":        "expo start --android",
    "ios":            "expo start --ios",
    "test":           "jest",
    "lint":           "eslint src --ext .ts,.tsx",
    "type-check":     "tsc --noEmit",
    "backend:start":  "npm --prefix backend install --production && node backend/server.js"
  },
  "dependencies": {
    "expo":                                      "~50.0.0",
    "expo-status-bar":                           "~1.11.1",
    "expo-notifications":                        "~0.27.0",
    "expo-image-picker":                         "~14.7.0",
    "expo-file-system":                          "~16.0.0",
    "expo-linear-gradient":                      "~12.7.0",
    "expo-camera":                               "~14.0.0",
    "expo-av":                                   "~13.10.0",
    "expo-device":                               "~5.9.0",
    "expo-location":                             "~16.5.0",
    "react":                                     "18.2.0",
    "react-native":                              "0.73.0",
    "zustand":                                   "^4.5.2",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-navigation/native":                  "^6.1.9",
    "@react-navigation/native-stack":            "^6.9.17",
    "@react-navigation/bottom-tabs":             "^6.5.11",
    "react-native-safe-area-context":            "4.8.2",
    "react-native-screens":                      "~3.29.0",
    "react-native-reanimated":                   "~3.6.0",
    "react-native-gesture-handler":              "~2.14.0",
    "react-native-linear-gradient":              "^2.8.3",
    "react-native-background-fetch":             "^4.2.1",
    "react-native-webrtc":                       "^118.0.0",
    "@expo/vector-icons":                        "^14.0.0",
    "@stripe/stripe-react-native":               "0.37.2",
    "@rnmapbox/maps":                            "^10.1.10",
    "@livekit/react-native":                     "^2.2.0",
    "@livekit/react-native-webrtc":              "^125.0.8",
    "@supabase/supabase-js":                     "^2.39.0",
    "socket.io-client":                          "^4.7.2",
    "axios":                                     "^1.6.7"
  },
  "devDependencies": {
    "@babel/core":                      "^7.20.0",
    "@types/react":                     "~18.2.45",
    "@types/react-native":              "~0.73.0",
    "@types/react-native-webrtc":       "^1.0.0",
    "typescript":                       "^5.3.0",
    "jest":                             "^29.7.0",
    "@testing-library/react-native":    "^12.4.0",
    "eslint":                           "^8.0.0",
    "@typescript-eslint/parser":        "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "babel-plugin-module-resolver":     "^5.0.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleNameMapper": {
      "^@core/(.*)$":        "<rootDir>/src/core/$1",
      "^@services/(.*)$":    "<rootDir>/src/services/$1",
      "^@screens/(.*)$":     "<rootDir>/src/screens/$1",
      "^@components/(.*)$":  "<rootDir>/src/components/$1",
      "^@utils/(.*)$":       "<rootDir>/src/utils/$1",
      "^@types/index$":      "<rootDir>/src/types/index",
      "^@config/(.*)$":      "<rootDir>/src/config/$1",
      "^@navigation/(.*)$":  "<rootDir>/src/navigation/$1",
      "^@hooks/(.*)$":       "<rootDir>/src/hooks/$1"
    }
  },
  "private": true
}
